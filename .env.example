# --- INFRA ---
DOMAIN_NAME=XXXXXXXXXXXX
SSL_EMAIL=XXXXXXXX
GENERIC_TIMEZONE=Europe/Paris

# --- POSTGRESQL ---
POSTGRES_USER=XXXXXXXXXXXX
POSTGRES_PASSWORD=XXXXXXXXXXXX
POSTGRES_DB=XXXXXXXXXXXX

# --- N8N TUNING (VPS < 4GB RAM) ---
# Force n8n à écrire les fichiers binaires sur le disque au lieu de la RAM
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
# Limite la heap Node.js pour éviter le crash OOM (ajuster selon votre VPS, ex: 1024 ou 2048)
NODE_OPTIONS=--max-old-space-size=1536